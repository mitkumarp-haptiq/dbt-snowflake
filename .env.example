# Snowflake (used by dbt profile learn_dbt)
# If a value is missing, omit the line — KEY= with nothing after still sets an empty variable.
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=DBT_USER

# Default dbt target `dev`: key-pair auth (PEM private key path). Register the matching
# public key on the Snowflake user (ALTER USER ... SET RSA_PUBLIC_KEY='...';).
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
# Only if the PEM is encrypted:
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Optional: target `dev_password` (dbt --target dev_password) when MFA does not apply.
# SNOWFLAKE_PASSWORD=

SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=ANALYTICS_DEV
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
# Do not use INFORMATION_SCHEMA here — use your dbt / raw schema (e.g. PUBLIC).
# Use the same spelling Snowflake uses (usually uppercase); the flow normalizes to uppercase.
SNOWFLAKE_SCHEMA=DBT_MIT

# dbt looks for profiles in this directory when set
DBT_PROFILES_DIR=learn_dbt

# Postgres (flows/postgres_to_snowflake — local or any reachable server)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=mydb
# Optional defaults for `python flows/postgres_to_snowflake/main.py`
# Required for a real copy: SQL that selects the rows/columns you want in Snowflake.
# POSTGRES_COPY_SQL=SELECT id, col FROM public.my_table
# SNOWFLAKE_LOAD_TABLE=MY_RAW_TABLE
# Overwrite Snowflake table each run with this extract only (no duplicate appends).
# SNOWFLAKE_LOAD_REPLACE=true
# How many Postgres rows to log as a preview (0 = dtypes/count only).
# POSTGRES_LOG_SAMPLE_ROWS=15

# Structured logging (structlog)
# STRUCTLOG_JSON=true for JSON lines; omit for pretty console.
# STRUCTLOG_JSON=true
# Minimum log level: DEBUG, INFO, WARNING, ERROR.
# STRUCTLOG_LOG_LEVEL=INFO

# CDC: Postgres -> Debezium -> Redpanda -> Prefect flow (every 2 min) -> Snowflake.
# The Prefect flow drains Redpanda and bulk-MERGEs into Snowflake -- one
# warehouse spin-up per batch keeps Snowflake cost minimal.

# Kafka bootstrap (Redpanda exposed on host port 9092).
# CDC_KAFKA_BOOTSTRAP=localhost:9092

# Topic Debezium publishes to (matches table.include.list / CDC_SOURCE_TABLE_INCLUDE).
# Format: <topic.prefix>.<schema>.<table>. Default stack uses public.users -> app.public.users.
# CDC_KAFKA_TOPIC=app.public.users
# If you add public.customers to Debezium, set CDC_KAFKA_TOPIC=app.public.customers here.

# Consumer group; offsets are stored per-group in Redpanda.
# CDC_KAFKA_GROUP_ID=cdc-snowflake-loader

# Snowflake destination. Auto-created on first run if missing.
# CDC_SNOWFLAKE_TABLE=CDC_CUSTOMERS
# CDC_PRIMARY_KEY_COLUMN=id

# Drain limits. The flow stops at whichever fires first:
#   max_seconds total, idle_seconds without a new message, or max_messages.
# CDC_DRAIN_MAX_SECONDS=90
# CDC_DRAIN_IDLE_SECONDS=5
# CDC_DRAIN_MAX_MESSAGES=50000

# Event-driven trigger bridge: consumes Kafka topic activity and POSTs to a
# Prefect Automation webhook URL. The automation can trigger your deployment.
# If using Docker compose trigger service, use redpanda:29092; for local testing use localhost:9092.
# CDC_KAFKA_BOOTSTRAP=redpanda:29092
# CDC_KAFKA_TOPIC=app.public.users
# CDC_TRIGGER_GROUP_ID=cdc-prefect-webhook-bridge
# CDC_TRIGGER_COOLDOWN_SECONDS=120
# CDC_TRIGGER_HTTP_TIMEOUT_SECONDS=10
# Required for webhook mode (create in Prefect UI Automation > Webhook):
# PREFECT_CDC_WEBHOOK_URL=https://.../automations/webhooks/<id>

# Azure Monitor / Application Insights (optional)
# When set, Prefect + pipeline logs are sent directly to Azure Monitor.
# No separate OpenTelemetry collector is required.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...
# Optional service name shown in Azure Monitor / Grafana.
# AZURE_MONITOR_SERVICE_NAME=postgres-to-snowflake
