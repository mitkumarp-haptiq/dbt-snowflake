# Comma-separated list of Debezium topics to ingest.
# Pattern is <topic.prefix>.<schema>.<table>.
TOPICS=app.public.users

# Comma-separated topic-to-table mapping used by Snowflake connector.
# Use uppercase Snowflake tables in a RAW schema.
# Example:
# TOPIC_TABLE_MAP=app.public.users:CDC_USERS_RAW,app.public.orders:CDC_ORDERS_RAW
TOPIC_TABLE_MAP=app.public.users:CDC_USERS_RAW
